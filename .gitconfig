[user]
	name = shonakam
	email = g3tsuzumi@gmail.com
[core]
	precomposeunicode = true
	quotepath = false
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[url "git@github.com:"]
	insteadOf = https://github.com
[push]
	autoSetupRemote = true
